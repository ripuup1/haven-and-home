<script type="text/javascript" id="wpaabrr-origin-js-after">
/* <![CDATA[ */
(function(){
  function isAllowedAmazonHost(host){
    host = (host || '').toLowerCase();
    if (!host) return false;
    if (host === 'amzn.to' || host.endsWith('.amzn.to')) return true;
    return /(^|\.)amazon\.[a-z0-9\-\.]+$/.test(host);
  }
  function isAllowedAmazonUrl(href){
    try {
      if (!href) return false;
      if (href.startsWith('//')) href = location.protocol + href;
      var url = new URL(href, location.href);
      if (url.protocol !== 'http:' && url.protocol !== 'https:') return false;
      return isAllowedAmazonHost(url.hostname);
    } catch(e){
      return false;
    }
  }
  function isModifiedClick(ev){
    return ev.metaKey || ev.ctrlKey || ev.shiftKey || ev.altKey;
  }
  function navigateWithoutReferrer(url, target){
    if (!url) return;
    var anchor = document.createElement('a');
    anchor.href = url;
    anchor.rel = 'noreferrer noopener';
    anchor.referrerPolicy = 'no-referrer';
    anchor.target = target || '_self';
    anchor.style.display = 'none';
    document.body.appendChild(anchor);
    anchor.click();
    document.body.removeChild(anchor);
  }
  function openPendingWindow(){
    try {
      var win = window.open('', '_blank');
      if (!win) return null;
      try {
        win.document.open();
        win.document.write('<!doctype html><html><!--- WPEL PLACEHOLDER 1 ---><body>Opening...<div class="mads-block"></div></body></html>');
        win.document.close();
      } catch(e){}
      return win;
    } catch(e){
      return null;
    }
  }
  function navigatePendingWindow(win, url){
    if (!win || win.closed || !url) return false;
    try {
      win.opener = null;
    } catch(e){}
    try {
      var html = '<!doctype html><html><!--- WPEL PLACEHOLDER 2 ---><body><script>window.location.replace(' + JSON.stringify(String(url)) + ');<\/script><noscript><meta http-equiv="refresh" content="0;url=' + String(url).replace(/&/g,'&amp;').replace(/"/g,'&quot;') + '"></noscript><div class="mads-block"></div></body></html>';
      win.document.open();
      win.document.write(html);
      win.document.close();
      return true;
    } catch(e){
      return false;
    }
  }
  async function getSignedUrl(amazonUrl){
    var cfg = window.WPAABRR_ORIGIN_CFG || {};
    if (!cfg.restSignUrl || !cfg.postId || Number(cfg.postId) < 1) return null;
    var url = cfg.restSignUrl + (cfg.restSignUrl.indexOf('?') === -1 ? '?' : '&') + 'u=' + encodeURIComponent(amazonUrl) + '&pid=' + encodeURIComponent(String(cfg.postId));
    var res = await fetch(url, { credentials: 'same-origin' });
    if (!res.ok) return null;
    var data = await res.json();
    if (!data || !data.ok || !data.url) return null;
    return data.url;
  }

  document.addEventListener('click', async function(ev){
    if (ev.defaultPrevented || isModifiedClick(ev) || ev.button !== 0) return;

    var link = ev.target && ev.target.closest ? ev.target.closest('a[href]') : null;
    if (!link) return;

    var href = link.getAttribute('href') || '';
    if (!href) return;

    var lower = href.toLowerCase();
    if (lower.startsWith('mailto:') || lower.startsWith('tel:') || lower.startsWith('javascript:') || lower.startsWith('#')) return;
    if (!isAllowedAmazonUrl(href)) return;

    ev.preventDefault();
    ev.stopPropagation();
    if (typeof ev.stopImmediatePropagation === 'function') {
      ev.stopImmediatePropagation();
    }

     try {
      var opensNewTab = (link.getAttribute('target') || '').toLowerCase() === '_blank';
      var pendingWindow = null;
      if (opensNewTab) {
        pendingWindow = openPendingWindow();
      }

      var signedUrl = await getSignedUrl(href);
      if (!signedUrl) {
        if (navigatePendingWindow(pendingWindow, href)) {
          return;
        }
        if (pendingWindow && !pendingWindow.closed) {
          try { pendingWindow.close(); } catch(e){}
        }
        navigateWithoutReferrer(href, opensNewTab ? '_blank' : '_self');
        return;
      }

      if (navigatePendingWindow(pendingWindow, signedUrl)) {
        return;
      }
      if (pendingWindow && !pendingWindow.closed) {
        try { pendingWindow.close(); } catch(e){}
      }
      navigateWithoutReferrer(signedUrl, opensNewTab ? '_blank' : '_self');
    } catch(e){
      navigateWithoutReferrer(href, (link.getAttribute('target') || '').toLowerCase() === '_blank' ? '_blank' : '_self');
    }
  }, true);
})();
//# sourceURL=wpaabrr-origin-js-after
/* ]]> */
</script>
